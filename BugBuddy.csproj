<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>

    <!-- Global Tool Ayarları -->
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>bugbuddy</ToolCommandName>
    <PackageOutputPath>./nupkg</PackageOutputPath>

    <!-- Paket Bilgileri -->
    <PackageId>BugBuddy</PackageId>
    <Version>1.0.0</Version>
    <Authors>BugBuddy</Authors>
    <Description>AI-powered friendly build error explainer for .NET developers</Description>
    <PackageTags>dotnet;tool;ai;errors;build;developer-tools</PackageTags>
    <RepositoryUrl>https://github.com/yourusername/BugBuddy</RepositoryUrl>
    <License>MIT</License>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="test-project\**" />
    <EmbeddedResource Remove="test-project\**" />
    <None Remove="test-project\**" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Spectre.Console" Version="0.49.*" />
    <PackageReference Include="System.CommandLine" Version="2.0.0-beta4.22272.1" />
  </ItemGroup>

</Project>
